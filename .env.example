# Environment Variables Template for CortexOS
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control

# ============================================
# 🔑 Required Configuration
# ============================================

# Default LLM Provider (groq, openai, anthropic, gemini, mistral, openrouter, ollama)
LLM_PROVIDER=groq

# ============================================
# 🤖 AI Provider API Keys
# Only configure the providers you plan to use
# ============================================

# Groq (Fast inference - Recommended for development)
# Get key: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI
# Get key: https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Anthropic (Claude)
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Google Gemini
# Get key: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Mistral AI
# Get key: https://console.mistral.ai
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-small-latest

# OpenRouter (Access to multiple models)
# Get key: https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Ollama (Local models - No API key needed)
# Download: https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ============================================
# 🗄️ Database Configuration
# ============================================

# PostgreSQL Database URL
# Example: postgresql://user:password@localhost:5432/cortexos
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cortexos

# ============================================
# 🔐 Authentication & Security
# ============================================

# Next.js Secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Session Configuration
SESSION_MAX_AGE=2592000

# ============================================
# 🌐 Application Settings
# ============================================

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Debug Mode (set to 'true' for verbose logging)
DEBUG_MODE=false

# ============================================
# 🧠 Knowledge Base (Vector Database)
# ============================================

# ChromaDB Configuration (optional - for RAG features)
CHROMA_DB_URL=http://localhost:8000
CHROMA_COLLECTION=cortexos_knowledge

# ============================================
# 📊 Analytics & Monitoring (Optional)
# ============================================

# Sentry (Error tracking)
# SENTRY_DSN=your_sentry_dsn_here

# PostHog (Product analytics)
# NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key_here
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ============================================
# 📧 Email Configuration (Optional - for notifications)
# ============================================

# SMTP Settings
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password

# ============================================
# 🔔 Notification Services (Optional)
# ============================================

# Telegram Bot (for notifications)
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# Discord Webhook
# DISCORD_WEBHOOK_URL=your_discord_webhook_url

# ============================================
# 📝 Notes:
# ============================================
# 1. After copying this file to .env.local, replace all placeholder values
# 2. Never commit .env.local to git - it's already in .gitignore
# 3. Restart your development server after changing environment variables
# 4. For production, use secure secret generation and proper database credentials
# 5. Run `pnpm db:migrate` after setting up the database
